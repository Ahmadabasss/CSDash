# ── data source ──────────────────────────────────────────────────────────────
# "mock"  → read from data/big-mock-data/generated/scenarios/<MOCK_SCENARIO>/
# "sql"   → read from Azure SQL Database (requires SQL_SERVER + SQL_DATABASE)
DATA_SOURCE=mock
MOCK_SCENARIO=noisy

FRONTEND_ORIGIN=http://localhost:3000

# ── Azure SQL Database (DATA_SOURCE=sql) ──────────────────────────────────────
# Auth: DefaultAzureCredential (passwordless)
#   • In Azure: assign a Managed Identity to the app, then:
#       CREATE USER [<identity-name>] FROM EXTERNAL PROVIDER;
#       ALTER ROLE db_datareader ADD MEMBER [<identity-name>];
#   • Locally: run `az login` once, then start the server normally.
SQL_SERVER=vigil-sql.database.windows.net
SQL_DATABASE=vigil-security

# ── Azure credential env vars (optional — only if NOT using az login locally) ─
# These are picked up automatically by DefaultAzureCredential.
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=

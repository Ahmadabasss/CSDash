# ── data source ──────────────────────────────────────────────────────────────
# "sql"   → read from Azure SQL Database (recommended)
# "mock"  → read from local JSON files (no database needed, for local dev only)
DATA_SOURCE=sql
MOCK_SCENARIO=noisy

FRONTEND_ORIGIN=http://localhost:3000

# ── Azure SQL Database ────────────────────────────────────────────────────────
# Replace with your actual Azure SQL Server and database name.
# Example: SQL_SERVER=vigil-sql.database.windows.net
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=your-database-name

# ── Authentication (passwordless — no secrets needed) ─────────────────────────
# In Azure: assign a System-assigned Managed Identity to the app, then run:
#   CREATE USER [<identity-name>] FROM EXTERNAL PROVIDER;
#   ALTER ROLE db_datareader ADD MEMBER [<identity-name>];
#   ALTER ROLE db_datawriter ADD MEMBER [<identity-name>];
#
# Locally: just run `az login` once, then start the server — no other config needed.

# ── Optional: service principal (CI/CD or if not using az login) ──────────────
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
